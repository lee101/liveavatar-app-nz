FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04@sha256:17e2934e1fa96152b14f78078bfbafd0f00f391df995dc6c641a720fce1202bb

ARG LIVEAVATAR_COMMIT=76489bc1c6718edbf610009bcd5e5436b0dc8459
ENV COG_PREDICT_TYPE_STUB=predict.py:Predictor \
    DEBIAN_FRONTEND=noninteractive \
    HF_HUB_DISABLE_TELEMETRY=1 \
    NVIDIA_DRIVER_CAPABILITIES=all \
    PORT=5000 \
    PYTHONUNBUFFERED=1

RUN apt-get update -qq \
    && apt-get install -qqy --no-install-recommends \
        ca-certificates curl ffmpeg libgl1 libglib2.0-0 libsndfile1 python3 python3-pip \
    && mkdir -p /opt/liveavatar \
    && curl -fsSL "https://github.com/Alibaba-Quark/LiveAvatar/archive/${LIVEAVATAR_COMMIT}.tar.gz" \
        | tar -xz --strip-components=1 -C /opt/liveavatar \
    && apt-get purge -qqy curl \
    && apt-get autoremove -qqy \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir --no-deps \
        torch==2.8.0 torchvision==0.23.0 torchaudio==2.8.0 \
        --index-url https://download.pytorch.org/whl/cu128 \
    && python3 -m pip install --no-cache-dir \
        cog==0.21.0 \
        'diffusers>=0.31.0' transformers==4.51.3 'tokenizers>=0.20.3' \
        'accelerate>=1.1.1' peft==0.17.1 safetensors huggingface_hub hf_transfer \
        'imageio[ffmpeg]' imageio-ffmpeg 'opencv-python-headless>=4.9.0.80' \
        'numpy>=1.23.5,<2' pillow librosa decord easydict einops ftfy regex \
        pyyaml scipy tqdm nvidia-cuda-cupti-cu12 nvidia-cuda-nvrtc-cu12 \
        nvidia-cusparselt-cu12 nvidia-nccl-cu12 \
    && python3 -m pip install --no-cache-dir --no-deps \
        'https://github.com/windreamer/flash-attention3-wheels/releases/download/2026.05.20-072445f/flash_attn_3-3.0.0%2B20260519.cu128torch280cxx11abitrue.8a8b2f-cp39-abi3-linux_x86_64.whl' \
    && python3 -m pip freeze \
        | awk -F== '/^nvidia-/ && $1 != "nvidia-cuda-cupti-cu12" && $1 != "nvidia-cuda-nvrtc-cu12" && $1 != "nvidia-cusparselt-cu12" && $1 != "nvidia-nccl-cu12" {print $1}' \
        | xargs -r python3 -m pip uninstall -y

WORKDIR /src
COPY inputs.py predict.py weights.py /src/

EXPOSE 5000
CMD ["python3", "-m", "cog.server.http"]
